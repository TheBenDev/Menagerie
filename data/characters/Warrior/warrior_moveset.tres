[gd_resource type="Resource" script_class="CombatMovesetData" format=3 uid="uid://dmirfj36xyajo"]

[ext_resource type="Script" uid="uid://3btd2ryissk0" path="res://scripts/data/actions/combat_moveset_data.gd" id="1_moveset"]
[ext_resource type="Script" uid="uid://bvhvlkmv0thup" path="res://scripts/data/actions/player_action_data.gd" id="2_player_action"]
[ext_resource type="Script" uid="uid://did5gnthi0qvc" path="res://scripts/data/actions/combat_action_data.gd" id="3_combat_action"]
[ext_resource type="Script" uid="uid://bj802nmis6fsn" path="res://scripts/data/effects/action_effect.gd" id="4_action_effect"]

[sub_resource type="Resource" id="DamageEffect_quick_strike"]
script = ExtResource("4_action_effect")
effect_id = &"combat.damage"
base_damage = 4
scaling_multiplier = 1.0

[sub_resource type="Resource" id="RageGainEffect_quick_strike"]
script = ExtResource("4_action_effect")
effect_id = &"resource.rage.gain"
amount = 3

[sub_resource type="Resource" id="PlayerAction_quick_strike"]
script = ExtResource("2_player_action")
id = "quick_strike"
display_name = "Quick Strike"
time_cost = 3.0
effects = Array[ExtResource("4_action_effect")]([SubResource("DamageEffect_quick_strike"), SubResource("RageGainEffect_quick_strike")])

[sub_resource type="Resource" id="DamageEffect_heavy_strike"]
script = ExtResource("4_action_effect")
effect_id = &"combat.damage"
base_damage = 14
scaling_multiplier = 1.5

[sub_resource type="Resource" id="ApplyStatusEffect_heavy_strike_vulnerable"]
script = ExtResource("4_action_effect")
effect_id = &"status.apply"
status_id = &"status.vulnerable"

[sub_resource type="Resource" id="RageGainEffect_heavy_strike"]
script = ExtResource("4_action_effect")
effect_id = &"resource.rage.gain"
amount = 6

[sub_resource type="Resource" id="PlayerAction_heavy_strike"]
script = ExtResource("2_player_action")
id = "heavy_strike"
display_name = "Heavy Strike"
time_cost = 8.0
effects = Array[ExtResource("4_action_effect")]([SubResource("DamageEffect_heavy_strike"), SubResource("ApplyStatusEffect_heavy_strike_vulnerable"), SubResource("RageGainEffect_heavy_strike")])

[sub_resource type="Resource" id="BlockEffect_guard"]
script = ExtResource("4_action_effect")
effect_id = &"combat.block"
amount = 12

[sub_resource type="Resource" id="PlayerAction_guard"]
script = ExtResource("2_player_action")
id = "guard"
display_name = "Guard"
effects = Array[ExtResource("4_action_effect")]([SubResource("BlockEffect_guard")])
target_enemy = false

[resource]
script = ExtResource("1_moveset")
actions = Array[ExtResource("3_combat_action")]([SubResource("PlayerAction_quick_strike"), SubResource("PlayerAction_heavy_strike"), SubResource("PlayerAction_guard")])
