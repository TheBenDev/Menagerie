[gd_resource type="Resource" script_class="AudioLibraryData" format=3]

[ext_resource type="Script" path="res://scripts/data/audio/audio_library_data.gd" id="1_library"]
[ext_resource type="Script" path="res://scripts/data/audio/music_track_data.gd" id="2_music_track"]
[ext_resource type="AudioStream" path="res://sounds/music/bgtheme.wav" id="3_bgtheme"]
[ext_resource type="AudioStream" path="res://sounds/music/Dungeon/cautious_battle.wav" id="4_cautious_battle"]
[ext_resource type="AudioStream" path="res://sounds/music/Dungeon/dramtic_battle.wav" id="5_dramtic_battle"]
[ext_resource type="AudioStream" path="res://sounds/music/Dungeon/eerie_exploration.wav" id="6_eerie_exploration"]
[ext_resource type="AudioStream" path="res://sounds/music/Dungeon/impending_doom.wav" id="7_impending_doom"]
