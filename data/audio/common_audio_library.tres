[ext_resource type="AudioStream" path="res://sounds/ui/Button/Click.wav" id="9_button_click"]
[ext_resource type="AudioStream" path="res://sounds/sfx/Boss/Global/Death/RunEndsLoop.wav" id="10_run_ends_loop"]
