[sub_resource type="Resource" id="MusicTrack_main_menu"]
script = ExtResource("2_music_track")
id = &"main_menu"
base_stream = ExtResource("3_bgtheme")
bus = &"Music"
volume_db = -8.0
default_fade_seconds = 2.0
loop = true

[sub_resource type="Resource" id="MusicTrack_waiting_room"]
script = ExtResource("2_music_track")
id = &"waiting_room"
base_stream = ExtResource("3_bgtheme")
bus = &"Music"
volume_db = -8.0
default_fade_seconds = 2.0
loop = true

[sub_resource type="Resource" id="MusicTrack_dungeon"]
script = ExtResource("2_music_track")
id = &"dungeon"
base_stream = ExtResource("6_eerie_exploration")
playlist_streams = Array[AudioStream]([ExtResource("4_cautious_battle"), ExtResource("5_dramtic_battle"), ExtResource("6_eerie_exploration"), ExtResource("7_impending_doom")])
randomize_playlist = true
avoid_immediate_repeats = true
playlist_crossfade_min_seconds = 5.0
playlist_crossfade_max_seconds = 10.0
bus = &"Music"
volume_db = -8.0
default_fade_seconds = 5.0
loop = true

[sub_resource type="Resource" id="MusicTrack_combat"]
script = ExtResource("2_music_track")
id = &"combat"
