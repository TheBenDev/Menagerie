[gd_resource type="Resource" script_class="ClassStanceData" format=3]

[ext_resource type="Script" path="res://core/combat/classes/class_stance_data.gd" id="1_stance"]

[resource]
script = ExtResource("1_stance")
id = &"berserker"
display_name = "Berserker"
description = "A reckless stance focused on Rage pressure and burst damage. Entry bonus: gain 10 Rage."
tags = Array[StringName]([&"warrior", &"berserker"])
