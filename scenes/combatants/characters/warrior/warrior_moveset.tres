[sub_resource type="Resource" id="ActionEffect_quick_strike_damage"]
script = ExtResource("4_action_effect")
effect_id = &"combat.damage"
base_damage = 4
scaling_multiplier = 1.0

[sub_resource type="Resource" id="ActionEffect_quick_strike_rage_gain"]
script = ExtResource("4_action_effect")
effect_id = &"resource.rage.gain"
amount = 3

[sub_resource type="Resource" id="PlayerAction_quick_strike"]
script = ExtResource("2_player_action")
id = "quick_strike"
display_name = "Quick Strike"
time_cost = 3.0
effects = Array[ExtResource("4_action_effect")]([SubResource("ActionEffect_quick_strike_damage"), SubResource("ActionEffect_quick_strike_rage_gain")])

[sub_resource type="Resource" id="ActionEffect_heavy_strike_damage"]
script = ExtResource("4_action_effect")
effect_id = &"combat.damage"
base_damage = 14
scaling_multiplier = 1.5

[sub_resource type="Resource" id="ActionEffect_heavy_strike_vulnerable_status"]
script = ExtResource("4_action_effect")
effect_id = &"status.apply"
status_id = &"status.vulnerable"

[sub_resource type="Resource" id="ActionEffect_heavy_strike_rage_gain"]
script = ExtResource("4_action_effect")
effect_id = &"resource.rage.gain"
