[sub_resource type="Resource" id="PlayerAction_heavy_strike"]
script = ExtResource("2_player_action")
id = "heavy_strike"
display_name = "Heavy Strike"
time_cost = 8.0
effects = Array[ExtResource("4_action_effect")]([SubResource("ActionEffect_heavy_strike_damage"), SubResource("ActionEffect_heavy_strike_vulnerable_status"), SubResource("ActionEffect_heavy_strike_rage_gain")])

[sub_resource type="Resource" id="ActionEffect_guard_block"]
script = ExtResource("4_action_effect")
effect_id = &"combat.block"
amount = 12

[sub_resource type="Resource" id="PlayerAction_guard"]
script = ExtResource("2_player_action")
id = "guard"
display_name = "Guard"
effects = Array[ExtResource("4_action_effect")]([SubResource("ActionEffect_guard_block")])
target_enemy = false

[resource]
script = ExtResource("1_moveset")
actions = Array[ExtResource("3_combat_action")]([SubResource("PlayerAction_quick_strike"), SubResource("PlayerAction_heavy_strike"), SubResource("PlayerAction_guard")])
