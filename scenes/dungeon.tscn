[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/dungeon/dungeon_controller.gd" id="1_dungeon_controller"]
[ext_resource type="Script" path="res://scripts/dungeon/dungeon_node_view.gd" id="2_node_view"]
[ext_resource type="PackedScene" path="res://scenes/UI/GlobalHUD/GlobalHUD.tscn" id="3_global_hud"]
[ext_resource type="Theme" path="res://assets/ui/menagerie_theme.tres" id="4_theme"]

[node name="Dungeon" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("4_theme")

[node name="Backdrop" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.075, 0.08, 0.085, 1)

[node name="DungeonController" type="Node" parent="."]
script = ExtResource("1_dungeon_controller")
node_container_path = NodePath("../MarginContainer/Layout/PathPanel/PathMargin/PathRow")

[node name="GlobalHUD" parent="." instance=ExtResource("3_global_hud")]

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 44
theme_override_constants/margin_top = 112
theme_override_constants/margin_right = 44
theme_override_constants/margin_bottom = 36

[node name="Layout" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 18

[node name="HeaderRow" type="HBoxContainer" parent="MarginContainer/Layout"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="TitleLabel" type="Label" parent="MarginContainer/Layout/HeaderRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 42
text = "Dungeon"

[node name="DifficultyLabel" type="Label" parent="MarginContainer/Layout/HeaderRow"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Difficulty: Normal"
vertical_alignment = 1

[node name="StatusLabel" type="Label" parent="MarginContainer/Layout"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Progress: 0 / 4 fights complete"

[node name="PathPanel" type="PanelContainer" parent="MarginContainer/Layout"]
layout_mode = 2
size_flags_horizontal = 3

[node name="PathMargin" type="MarginContainer" parent="MarginContainer/Layout/PathPanel"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 22
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 22

[node name="PathRow" type="HBoxContainer" parent="MarginContainer/Layout/PathPanel/PathMargin"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="Node0Button" type="Button" parent="MarginContainer/Layout/PathPanel/PathMargin/PathRow"]
custom_minimum_size = Vector2(170, 96)
layout_mode = 2
script = ExtResource("2_node_view")
node_id = 0
node_type = "Haven"
text = "Current
Haven"

